PORT=5000
JWT_SECRET=change-this-secret
JWT_EXPIRE=24h

# Option 1: URL complete (recommande pour Render/TiDB)
# Exemple: mysql://user:password@host:4000/esp_antsiranana
DATABASE_URL=

# Option 2: variables separees (local)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=esp_antsiranana

# TiDB Cloud / MySQL TLS
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true
